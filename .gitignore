# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd

# ── Environments ─────────────────────────────────────────────────────────────
.env
.venv
env/
venv/
ENV/

# ── IDE / OS ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db

# ── Large data & model artifacts ─────────────────────────────────────────────
*.xlsx
*.csv
*.pkl
*.npy
*.zip

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log

# ── Binary outputs (PDFs, images) ────────────────────────────────────────────
# Exclude all PNGs and PDFs by default …
*.png
*.pdf

# … but allow the README screenshot folder explicitly
!images_for_readme/
!images_for_readme/**

# ── Scratch / temp files ─────────────────────────────────────────────────────
scratch/

# ── Streamlit cache ───────────────────────────────────────────────────────────
.streamlit/
